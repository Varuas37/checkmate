{
  "name": "checkmate.sh",
  "private": true,
  "version": "0.1.0",
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "scripts": {
    "dev": "node scripts/validate-vite-cache.mjs && vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc -b",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",
    "hooks:enable:basic": "bash scripts/install-git-hooks.sh --level basic",
    "hooks:enable:strict": "bash scripts/install-git-hooks.sh --level strict",
    "hooks:disable": "bash scripts/install-git-hooks.sh --level off",
    "hooks:remove": "bash scripts/install-git-hooks.sh --remove",
    "hooks:path": "git config --get core.hooksPath || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@reduxjs/toolkit": "^2.7.0",
    "@tauri-apps/api": "^2.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-loading-skeleton": "^3.5.0",
    "react-redux": "^9.2.0",
    "react-zoom-pan-pinch": "^3.7.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^5.4.15"
  }
}
